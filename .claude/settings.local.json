{
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "allowUnsandboxedCommands": false,
    "filesystem": {
      "allowWrite": [
        "~/.gradle/",
        "~/.android/",
        "~/.robolectric-download-lock"
      ],
      "allowRead": [
        "~/.gradle/",
        "~/.android/"
      ]
    },
    "permissions": {
      "allow": [
        "Bash(./gradlew assembleDebug)",
        "Bash(./gradlew testDebugUnitTest)",
        "Bash(git diff*)",
        "Bash(git log*)",
        "Bash(git status)",
        "Bash(git commit*)"
      ]
    },
    "network": {
      "allowLocalBinding": true
    }
  }
}
