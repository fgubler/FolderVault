<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Drive API + Firebase -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Android 13+: runtime notification permission; requested in onboarding -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Optional: observe network state changes for scheduling hints -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!--
        Android Auto Backup is disabled on purpose (BUG-11). The Room DB (foldervault.db) stores
        each backup config's password encrypted with a non-exportable AndroidKeyStore key, plus
        device-local SAF tree URIs and cloud-auth identifiers. None of that survives a move to
        another device: the Keystore key is gone on the new device (so the password blob becomes
        permanently undecryptable) and the SAF grants / auth are invalid there. Rather than
        restore a database full of dead, misleading state - or leak account ids and the full file
        index to Google's cloud backup unencrypted - we back up nothing at all. A returning user
        re-creates their backup configs and pulls their files back via the in-app restore flow,
        which only needs the backup password. That is why the dataExtractionRules /
        fullBackupContent rule files were removed: they are ignored while allowBackup is false.
    -->
    <application
        android:name=".FolderVaultApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.FolderVault">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.FolderVault">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Deep-link from problem notifications → backup detail screen -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data
                    android:scheme="foldervault"
                    android:host="backup"
                    android:pathPrefix="/detail" />
            </intent-filter>
        </activity>

        <!-- Koin WorkManager factory; WorkManager uses this to inject workers -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup" />
        </provider>

    </application>

</manifest>
