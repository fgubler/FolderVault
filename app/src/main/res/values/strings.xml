    <!-- Onboarding screen -->
    <string name="onboarding_skip">Skip</string>
    <string name="onboarding_next">Next</string>
    <string name="onboarding_get_started">Get started</string>
    <string name="onboarding_page1_title">Incremental folder backup</string>
    <string name="onboarding_page1_body">FolderVault backs up a folder on your device to Google Drive, automatically and in the background.</string>
    <string name="onboarding_page2_title">Best for files that rarely change</string>
    <string name="onboarding_page2_body">Photos, scans, and document archives are ideal. FolderVault is not designed for frequently-changing databases or app data.</string>
    <string name="onboarding_page3_title">Only new or changed files</string>
    <string name="onboarding_page3_body">Each run uploads only files that are new or have changed. Unchanged files are never re-sent — saving time and data.</string>
    <string name="onboarding_page4_title">Honest limitations</string>
    <string name="onboarding_page4_body">One-way push only — recovery means downloading from Drive and decrypting in-app. Changed files create timestamped copies. Re-installing the app means re-uploading everything from scratch. Nothing is ever deleted from Drive automatically.</string>
    <string name="onboarding_page5_title">Your files stay private</string>
    <string name="onboarding_page5_body">Enable AES-256-GCM encryption and only encrypted bytes ever leave your device. If you forget the password, the backup cannot be recovered — there is no reset.</string>
    <string name="onboarding_page6_title">Stay informed</string>
    <string name="onboarding_page6_body">Allow notifications so FolderVault can alert you if a backup stops working — without you having to open the app.</string>

